#
# Copy this file to `.env` for local development.
# Use `.env` rather than `.env.local` for values needed by Prisma and the CLI
# scripts in `package.json`, since many of them load env via `dotenv/config`.
#

# Core app / database
DATABASE_URL="postgresql://USER:PASSWORD@localhost:5432/autoapplication?schema=public"

# AI features imported from the tracker merge use Anthropic in this repo,
# not OpenAI. Leave blank to disable AI-assisted resume parsing, fit analysis,
# and cover letter generation.
ANTHROPIC_API_KEY=""
AI_MODEL="claude-sonnet-4-20250514"

# Optional secret for POST /api/ingestion/schedule in production.
INGESTION_CRON_SECRET=""

# Optional public API credentials
ADZUNA_APP_ID=""
ADZUNA_APP_KEY=""
USAJOBS_API_KEY=""
USAJOBS_EMAIL=""

# Optional source / coverage overrides
ADZUNA_COUNTRIES="ca,us"
ASHBY_ORG_TOKENS=""
GREENHOUSE_BOARD_TOKENS=""
HIMALAYAS_SOURCES="global"
ICIMS_PORTAL_TOKENS=""
LEVER_SITE_TOKENS=""
RECRUITEE_COMPANY_TOKENS=""
RIPPLING_BOARD_TOKENS=""
SMARTRECRUITERS_COMPANY_TOKENS=""
SUCCESSFACTORS_DOMAIN_TOKENS=""
TALEO_SOURCE_TOKENS=""
USAJOBS_KEYWORDS=""
WORKABLE_ACCOUNT_TOKENS=""
WORKDAY_SOURCE_TOKENS=""

# Optional schedule overrides, in minutes
ADZUNA_SCHEDULE_MINUTES=""
ASHBY_SCHEDULE_MINUTES=""
GREENHOUSE_SCHEDULE_MINUTES=""
HIMALAYAS_SCHEDULE_MINUTES=""
ICIMS_SCHEDULE_MINUTES=""
JOBBANK_SCHEDULE_MINUTES=""
JOBICY_SCHEDULE_MINUTES=""
LEVER_SCHEDULE_MINUTES=""
RECRUITEE_SCHEDULE_MINUTES=""
REMOTEOK_SCHEDULE_MINUTES=""
REMOTIVE_SCHEDULE_MINUTES=""
RIPPLING_SCHEDULE_MINUTES=""
SMARTRECRUITERS_SCHEDULE_MINUTES=""
SUCCESSFACTORS_SCHEDULE_MINUTES=""
TALEO_SCHEDULE_MINUTES=""
THEMUSE_SCHEDULE_MINUTES=""
USAJOBS_SCHEDULE_MINUTES=""
WORKABLE_SCHEDULE_MINUTES=""
WORKDAY_SCHEDULE_MINUTES=""
