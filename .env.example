#
# Copy this file to `.env` for local development.
# Use `.env` rather than `.env.local` for values needed by Prisma and the CLI
# scripts in `package.json`, since many of them load env via `dotenv/config`.
#

# Core app / database
DATABASE_URL="postgresql://USER:PASSWORD@localhost:5432/autoapplication?schema=public"

# Better Auth
BETTER_AUTH_SECRET=""
BETTER_AUTH_URL="http://localhost:3000"
NEXT_PUBLIC_BETTER_AUTH_URL="http://localhost:3000"

# OpenAI-backed AI features.
# Leave blank to disable resume parsing, fit analysis, and cover letter generation.
OPENAI_API_KEY=""
OPENAI_STANDARD_MODEL="gpt-4.1-mini"
OPENAI_REASONING_MODEL="gpt-5-mini"
OPENAI_FAST_MODEL="gpt-4o-mini"

# Optional secret for POST /api/ingestion/schedule in production.
INGESTION_CRON_SECRET=""

# Optional secret for POST /api/tracker/deadline-reminders in production.
TRACKER_CRON_SECRET=""

# Optional SMTP delivery for auth mail and deadline reminders.
SMTP_HOST=""
SMTP_PORT="587"
SMTP_USER=""
SMTP_PASS=""
SMTP_FROM=""

# Optional S3-compatible document storage.
# DigitalOcean Spaces example:
# STORAGE_PROVIDER="DigitalOcean Spaces"
# STORAGE_BUCKET="applicationflow-documents"
# STORAGE_REGION="tor1"
# STORAGE_ENDPOINT="https://tor1.digitaloceanspaces.com"
STORAGE_PROVIDER=""
STORAGE_BUCKET=""
STORAGE_REGION=""
STORAGE_ENDPOINT=""
STORAGE_ACCESS_KEY_ID=""
STORAGE_SECRET_ACCESS_KEY=""
STORAGE_FORCE_PATH_STYLE="false"

# Optional public API credentials
ADZUNA_APP_ID=""
ADZUNA_APP_KEY=""
JOOBLE_API_KEY=""
USAJOBS_API_KEY=""
USAJOBS_EMAIL=""
COMPANIES_HOUSE_API_KEY=""
OPENCORPORATES_API_TOKEN=""
GITHUB_FRONTIER_TOKEN=""
GITHUB_FRONTIER_API_VERSION="2022-11-28"
SEC_FRONTIER_USER_AGENT="autoapplication/1.0 frontier-seed"
SEC_EDGAR_EXCHANGES=""

# Optional source-family feature flags
ADZUNA_ENABLED="true"
JOBICY_ENABLED="true"
JOOBLE_ENABLED="false"
REMOTIVE_ENABLED="true"
THEMUSE_ENABLED="true"
USAJOBS_ENABLED="true"
WEWORKREMOTELY_ENABLED="true"

# Optional source / coverage overrides
ADZUNA_COUNTRIES="ca,us"
ADZUNA_ALLOW_NON_NA="false"
ADZUNA_SCHEDULE_PROFILES="techcore,specialist,discovery"
ASHBY_ORG_TOKENS=""
GREENHOUSE_BOARD_TOKENS=""
HIMALAYAS_SOURCES="global"
ICIMS_PORTAL_TOKENS=""
JOBICY_TAGS=""
JOOBLE_KEYWORDS=""
JOOBLE_LOCATIONS=""
JOOBLE_RESULTS_PER_PAGE=""
JOOBLE_MAX_PAGES=""
JOOBLE_SEARCHES_PER_RUN=""
JOOBLE_RATE_DELAY_MS=""
LEVER_SITE_TOKENS=""
RECRUITEE_COMPANY_TOKENS=""
RIPPLING_BOARD_TOKENS=""
SMARTRECRUITERS_COMPANY_TOKENS=""
SUCCESSFACTORS_DOMAIN_TOKENS=""
TALEO_SOURCE_TOKENS=""
THEMUSE_CATEGORIES=""
THEMUSE_LOCATIONS=""
USAJOBS_KEYWORDS=""
WORKABLE_ACCOUNT_TOKENS=""
WORKDAY_SOURCE_TOKENS=""

# Optional schedule overrides, in minutes
ADZUNA_SCHEDULE_MINUTES=""
ASHBY_SCHEDULE_MINUTES=""
GREENHOUSE_SCHEDULE_MINUTES=""
HIMALAYAS_SCHEDULE_MINUTES=""
ICIMS_SCHEDULE_MINUTES=""
JOBBANK_SCHEDULE_MINUTES=""
JOBICY_SCHEDULE_MINUTES=""
JOOBLE_SCHEDULE_MINUTES=""
LEVER_SCHEDULE_MINUTES=""
RECRUITEE_SCHEDULE_MINUTES=""
REMOTEOK_SCHEDULE_MINUTES=""
REMOTIVE_SCHEDULE_MINUTES=""
RIPPLING_SCHEDULE_MINUTES=""
SMARTRECRUITERS_SCHEDULE_MINUTES=""
SUCCESSFACTORS_SCHEDULE_MINUTES=""
TALEO_SCHEDULE_MINUTES=""
THEMUSE_SCHEDULE_MINUTES=""
USAJOBS_SCHEDULE_MINUTES=""
WORKABLE_SCHEDULE_MINUTES=""
WORKDAY_SCHEDULE_MINUTES=""

# Optional growth-mode overrides for visible supply correction passes
INGEST_GROWTH_MODE="false"
INGEST_FRONTIER_POLL_ONLY="false"
INGEST_GROWTH_FRONTIER_WINDOW_HOURS=""
INGEST_GROWTH_LOW_NOVELTY_RATIO_PERCENT=""
INGEST_GROWTH_LOW_NOVELTY_ACCEPTED_THRESHOLD=""
INGEST_GROWTH_FRONTIER_PRIORITY_BOOST=""
INGEST_GROWTH_NON_FRONTIER_PRIORITY_PENALTY=""
INGEST_GROWTH_REFRESH_HEAVY_PRIORITY_PENALTY=""
INGEST_GROWTH_HARD_COOLDOWN_HOURS=""
INGEST_GROWTH_SOURCE_QUERY_MULTIPLIER=""
