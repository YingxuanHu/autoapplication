{
  "name": "autoapplication",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "tsx -r dotenv/config scripts/run-app-stack.ts --mode=dev",
    "dev:web": "node --max-old-space-size=2048 ./node_modules/next/dist/bin/next dev --webpack",
    "dev:fresh": "rm -rf .next && npm run dev",
    "dev:turbo": "node --max-old-space-size=2048 ./node_modules/next/dist/bin/next dev",
    "dev:uncapped": "next dev",
    "build": "next build",
    "start": "tsx -r dotenv/config scripts/run-app-stack.ts --mode=start",
    "start:web": "next start",
    "lint": "eslint",
    "typecheck": "next typegen && tsc --noEmit",
    "db:backup": "bash scripts/db-backup.sh",
    "db:reset": "bash scripts/db-reset.sh",
    "ingest": "tsx -r dotenv/config scripts/ingest.ts",
    "source:discover": "tsx -r dotenv/config scripts/discover-sources.ts",
    "source:prune": "tsx -r dotenv/config scripts/prune-company-sources.ts",
    "source:reprioritize-imports": "tsx -r dotenv/config scripts/reprioritize-imported-source-tasks.ts",
    "company:seed": "tsx -r dotenv/config scripts/seed-company-discovery.ts",
    "company:seed:frontier": "tsx -r dotenv/config scripts/seed-company-frontier.ts",
    "enterprise:preflight": "tsx -r dotenv/config scripts/preflight-enterprise.ts",
    "enterprise:corpus": "tsx -r dotenv/config scripts/discover-company-corpus.ts",
    "enterprise:corpus:batches": "tsx -r dotenv/config scripts/run-company-corpus-batches.ts",
    "company:import-csv": "tsx -r dotenv/config scripts/import-company-seed-csv.ts",
    "source:sync-ats-tenants": "tsx -r dotenv/config scripts/sync-productive-ats-tenants.ts",
    "source:expand-ats-frontier": "tsx -r dotenv/config scripts/expand-ats-frontier.ts",
    "source:analyze-families": "tsx -r dotenv/config scripts/analyze-source-families.ts",
    "source:report-growth": "tsx -r dotenv/config scripts/report-supply-growth.ts",
    "source:bulk-direct-board-ingest": "tsx -r dotenv/config scripts/bulk-direct-board-ingest.ts",
    "source:run-frontier-growth-pass": "tsx -r dotenv/config scripts/run-frontier-growth-pass.ts",
    "source:retire-out-of-scope": "tsx -r dotenv/config scripts/retire-out-of-scope-source-mappings.ts",
    "jobs:backfill-region": "tsx -r dotenv/config scripts/backfill-canonical-region.ts",
    "workday:scout": "tsx -r dotenv/config scripts/scout-workday.ts",
    "workday:analyze": "tsx -r dotenv/config scripts/analyze-workday-sources.ts",
    "rippling:discover": "tsx -r dotenv/config scripts/discover-rippling.ts",
    "rippling:intake": "tsx -r dotenv/config scripts/discover-rippling.ts --no-search",
    "ingest:daemon": "tsx -r dotenv/config scripts/ingest-daemon.ts",
    "ingest:recovery-worker": "tsx -r dotenv/config scripts/ingest-recovery-worker.ts",
    "ingest:bulk-recovery": "tsx -r dotenv/config scripts/bulk-recovery-loop.ts",
    "network:ops": "tsx -r dotenv/config scripts/network-ops.ts",
    "daemon:start": "npx pm2 start ecosystem.config.cjs",
    "daemon:stop": "npx pm2 stop ingest-daemon",
    "daemon:restart": "npx pm2 restart ingest-daemon",
    "daemon:logs": "npx pm2 logs ingest-daemon",
    "daemon:status": "npx pm2 status",
    "classify": "tsx -r dotenv/config scripts/classify-eligibility.ts",
    "renormalize": "tsx -r dotenv/config scripts/renormalize-rejected.ts",
    "auto-apply": "tsx -r dotenv/config scripts/auto-apply.ts",
    "auto-apply:dry": "tsx -r dotenv/config scripts/auto-apply.ts --mode=dry_run",
    "auto-apply:fill": "tsx -r dotenv/config scripts/auto-apply.ts --mode=fill_only"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.1024.0",
    "@aws-sdk/s3-request-presigner": "^3.1024.0",
    "@base-ui/react": "^1.3.0",
    "@better-auth/prisma-adapter": "^1.5.6",
    "@faker-js/faker": "^10.4.0",
    "@prisma/adapter-pg": "^7.5.0",
    "@prisma/client": "^7.5.0",
    "@types/nodemailer": "^7.0.11",
    "better-auth": "^1.5.6",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "date-fns": "^4.1.0",
    "lucide-react": "^1.6.0",
    "mammoth": "^1.12.0",
    "next": "16.2.1",
    "next-themes": "^0.4.6",
    "nodemailer": "^8.0.4",
    "openai": "^6.33.0",
    "pdf-parse": "^2.4.5",
    "playwright": "^1.58.2",
    "prisma": "^7.5.0",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "shadcn": "^4.1.0",
    "tailwind-merge": "^3.5.0",
    "tw-animate-css": "^1.4.0",
    "word-extractor": "^1.0.4",
    "zod": "^4.3.6"
  },
  "prisma": {
    "seed": "npx tsx prisma/seed.ts"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "dotenv": "^17.3.1",
    "eslint": "^9",
    "eslint-config-next": "16.2.1",
    "tailwindcss": "^4",
    "tsx": "^4.21.0",
    "typescript": "^5"
  }
}
