generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// ─── Enums ──────────────────────────────────────────────

enum WorkMode {
  REMOTE
  HYBRID
  ONSITE
  FLEXIBLE
}

enum EmploymentType {
  FULL_TIME
  PART_TIME
  CONTRACT
  INTERNSHIP
}

enum ExperienceLevel {
  ENTRY
  MID
  SENIOR
  LEAD
  EXECUTIVE
}

enum Region {
  US
  CA
}

enum Industry {
  TECH
  FINANCE
}

enum SubmissionCategory {
  AUTO_SUBMIT_READY
  AUTO_FILL_REVIEW
  MANUAL_ONLY
}

enum AutomationMode {
  DISCOVERY_ONLY
  ASSIST
  REVIEW_BEFORE_SUBMIT
  STRICT_AUTO_APPLY
}

enum ApplicationStatus {
  DRAFT
  READY
  SUBMITTED
  CONFIRMED
  FAILED
  WITHDRAWN
}

enum SavedJobStatus {
  ACTIVE
  APPLIED
  EXPIRED
  DISMISSED
}

enum SourceTier {
  TIER_1
  TIER_2
  TIER_3
}

enum JobStatus {
  LIVE
  EXPIRED
  REMOVED
  STALE
}

enum UserAction {
  APPLY
  PASS
  SAVE
  VIEW_DETAILS
}

enum IngestionRunStatus {
  RUNNING
  SUCCESS
  FAILED
  SKIPPED
}

enum IngestionRunMode {
  MANUAL
  SCHEDULED
  API
}

enum DocumentType {
  RESUME
  COVER_LETTER
  RESUME_TEMPLATE
}

enum TrackedApplicationStatus {
  WISHLIST
  APPLIED
  SCREEN
  INTERVIEW
  OFFER
  REJECTED
  WITHDRAWN
}

enum TrackedApplicationEventType {
  APPLIED
  SCREEN
  INTERVIEW
  OFFER
  REJECTED
  NOTE
  REMINDER
}

enum TrackedApplicationDocumentSlot {
  SENT_RESUME
  SENT_COVER_LETTER
}

enum NotificationType {
  DEADLINE_REMINDER
  SYSTEM
}

enum DeadlineReminderType {
  DEADLINE_D7
  DEADLINE_D3
  DEADLINE_D1
  DEADLINE_TODAY
  DEADLINE_OVERDUE_D1
}

// ─── Models ─────────────────────────────────────────────

model User {
  id                        String              @id @default(cuid())
  email                     String              @unique
  name                      String
  emailVerified             Boolean             @default(false)
  emailNotificationsEnabled Boolean             @default(true)
  image                     String?
  createdAt                 DateTime            @default(now())
  updatedAt                 DateTime            @updatedAt

  accounts            Account[]
  sessions            Session[]
  profile             UserProfile?
  trackedApplications TrackedApplication[]
  tags                Tag[]
  notifications       Notification[]
  reminderLogs        ReminderLog[]
}

model UserProfile {
  id                String          @id @default(cuid())
  authUserId        String?         @unique
  email             String          @unique
  name              String
  phone             String?
  location          String?
  headline          String?
  summary           String?
  linkedinUrl       String?
  githubUrl         String?
  portfolioUrl      String?
  workAuthorization String?
  salaryMin         Int?
  salaryMax         Int?
  salaryCurrency    String?         @default("USD")
  preferredWorkMode WorkMode?
  experienceLevel   ExperienceLevel?
  automationMode    AutomationMode  @default(REVIEW_BEFORE_SUBMIT)

  // Structured profile data (rich JSON fields for AI ingestion and display)
  contactJson     Json?
  skillsText      String?
  experienceText  String?
  educationText   String?
  projectsText    String?
  skillsJson      Json?   // string[] — e.g. ["TypeScript", "React", "PostgreSQL"]
  experiencesJson Json?   // Array<{ title, company, location, startDate, endDate, description }>
  educationsJson  Json?   // Array<{ school, degree, field, startDate, endDate, description }>
  projectsJson    Json?   // Array<{ name, url, description, technologies }>

  createdAt         DateTime        @default(now())
  updatedAt         DateTime        @updatedAt

  authUser                User?                @relation(fields: [authUserId], references: [id], onDelete: Cascade)
  resumeVariants         ResumeVariant[]
  documents              Document[]
  preferences            UserPreference[]
  savedJobs              SavedJob[]
  behaviorSignals        UserBehaviorSignal[]
  applicationSubmissions ApplicationSubmission[]
  applicationPackages    ApplicationPackage[]
}

model ResumeVariant {
  id              String   @id @default(cuid())
  userId          String
  label           String
  targetRoleFamily String?
  fileUrl         String?
  content         String?
  isDefault       Boolean  @default(false)
  documentId      String?  @unique
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  user                UserProfile          @relation(fields: [userId], references: [id], onDelete: Cascade)
  document            Document?            @relation(fields: [documentId], references: [id], onDelete: SetNull)
  applicationPackages ApplicationPackage[]

  @@index([userId])
}

model Document {
  id            String       @id @default(cuid())
  userId        String
  type          DocumentType
  title         String
  originalFileName String
  filename      String
  mimeType      String
  sizeBytes     Int
  storageKey    String       @unique
  isPrimary     Boolean      @default(false)
  extractedText String?
  extractedAt   DateTime?
  createdAt     DateTime     @default(now())
  updatedAt     DateTime     @updatedAt

  user          UserProfile   @relation(fields: [userId], references: [id], onDelete: Cascade)
  analysis      DocumentAnalysis?
  resumeVariant ResumeVariant?
  trackedApplicationLinks TrackedApplicationDocument[]

  @@index([userId, type])
  @@index([userId, type, createdAt])
  @@index([userId, type, isPrimary])
}

model DocumentAnalysis {
  documentId            String   @id
  extractedText         String
  keywordsJson          Json
  sectionsJson          Json
  structuredProfileJson Json?
  importSummaryJson     Json?
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt

  document              Document @relation(fields: [documentId], references: [id], onDelete: Cascade)
}

model JobRaw {
  id         String     @id @default(cuid())
  sourceId   String
  sourceName String
  sourceTier SourceTier
  rawPayload Json
  fetchedAt  DateTime
  createdAt  DateTime   @default(now())

  sourceMappings JobSourceMapping[]

  @@unique([sourceName, sourceId])
}

model JobCanonical {
  id                 String          @id @default(cuid())
  title              String
  company            String
  companyKey         String          @default("")
  titleKey           String          @default("")
  titleCoreKey       String          @default("")
  descriptionFingerprint String      @default("")
  location           String
  locationKey        String          @default("")
  region             Region
  workMode           WorkMode
  salaryMin          Int?
  salaryMax          Int?
  salaryCurrency     String?         @default("USD")
  employmentType     EmploymentType
  experienceLevel    ExperienceLevel?
  description        String
  searchVector       Unsupported("tsvector")?
  shortSummary       String
  industry           Industry
  roleFamily         String
  applyUrl           String
  applyUrlKey        String?
  postedAt           DateTime
  deadline           DateTime?
  status             JobStatus       @default(LIVE)
  duplicateClusterId String?
  lastSeenAt         DateTime        @default(now())
  staleAt            DateTime?
  expiredAt          DateTime?
  removedAt          DateTime?
  createdAt          DateTime        @default(now())
  updatedAt          DateTime        @updatedAt

  eligibility            JobEligibility?
  sourceMappings         JobSourceMapping[]
  savedJobs              SavedJob[]
  applicationSubmissions ApplicationSubmission[]
  applicationPackages    ApplicationPackage[]
  behaviorSignals        UserBehaviorSignal[]
  trackedApplications    TrackedApplication[]

  // ── Deduplication indexes ──
  @@index([duplicateClusterId])
  @@index([applyUrlKey])
  @@index([companyKey, titleCoreKey, region])
  @@index([companyKey, roleFamily, region])
  @@index([companyKey, locationKey, region])
  @@index([companyKey, descriptionFingerprint, region])

  // ── Feed query indexes ──
  // Primary feed sort: status + postedAt covers the default newest-first ordering
  @@index([status, postedAt(sort: Desc)])
  // Region filter (very common): status + region + postedAt
  @@index([status, region, postedAt(sort: Desc)])
  // Role family filter: status + roleFamily + postedAt
  @@index([status, roleFamily, postedAt(sort: Desc)])
  // Work mode filter: status + workMode + postedAt
  @@index([status, workMode, postedAt(sort: Desc)])
  // Experience level filter: status + experienceLevel + postedAt
  @@index([status, experienceLevel, postedAt(sort: Desc)])
  // Industry filter: status + industry + postedAt
  @@index([status, industry, postedAt(sort: Desc)])
  // Salary filter: status + salaryMax for "min salary" filtering
  @@index([status, salaryMax(sort: Desc)])
  // Lifecycle reconciliation: status + lastSeenAt
  @@index([status, lastSeenAt])
}

model JobSourceMapping {
  id             String   @id @default(cuid())
  canonicalJobId String
  rawJobId       String
  sourceName     String
  sourceUrl      String?
  isPrimary      Boolean  @default(false)
  lastSeenAt     DateTime @default(now())
  removedAt      DateTime?
  createdAt      DateTime @default(now())

  canonicalJob JobCanonical @relation(fields: [canonicalJobId], references: [id], onDelete: Cascade)
  rawJob       JobRaw       @relation(fields: [rawJobId], references: [id], onDelete: Cascade)

  @@index([sourceName, removedAt])
  @@index([canonicalJobId, removedAt])
}

model JobEligibility {
  id                           String             @id @default(cuid())
  canonicalJobId               String             @unique
  submissionCategory           SubmissionCategory
  reasonCode                   String
  reasonDescription            String
  jobValidityConfidence        Float
  formAutomationConfidence     Float
  packageFitConfidence         Float
  submissionQualityConfidence  Float
  customizationLevel           Int
  evaluatedAt                  DateTime
  createdAt                    DateTime           @default(now())
  updatedAt                    DateTime           @updatedAt

  canonicalJob JobCanonical @relation(fields: [canonicalJobId], references: [id], onDelete: Cascade)

  // Feed filter by submission category
  @@index([submissionCategory])
}

model ApplicationPackage {
  id                String   @id @default(cuid())
  userId            String
  canonicalJobId    String
  resumeVariantId   String
  coverLetterContent String?
  savedAnswers      Json?
  attachedLinks     Json?
  whyItMatches      String?
  userNotes         String?
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  user          UserProfile   @relation(fields: [userId], references: [id], onDelete: Cascade)
  canonicalJob  JobCanonical  @relation(fields: [canonicalJobId], references: [id], onDelete: Cascade)
  resumeVariant ResumeVariant @relation(fields: [resumeVariantId], references: [id], onDelete: Cascade)
  submissions   ApplicationSubmission[]

  @@index([userId, canonicalJobId])
}

model ApplicationSubmission {
  id               String            @id @default(cuid())
  userId           String
  canonicalJobId   String
  packageId        String?
  status           ApplicationStatus
  submittedAt      DateTime?
  submissionMethod String?
  notes            String?
  createdAt        DateTime          @default(now())
  updatedAt        DateTime          @updatedAt

  user         UserProfile         @relation(fields: [userId], references: [id], onDelete: Cascade)
  canonicalJob JobCanonical        @relation(fields: [canonicalJobId], references: [id], onDelete: Cascade)
  package      ApplicationPackage? @relation(fields: [packageId], references: [id], onDelete: SetNull)

  @@index([userId, canonicalJobId])
}

model SavedJob {
  id             String        @id @default(cuid())
  userId         String
  canonicalJobId String
  status         SavedJobStatus @default(ACTIVE)
  notes          String?
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt

  user         UserProfile  @relation(fields: [userId], references: [id], onDelete: Cascade)
  canonicalJob JobCanonical @relation(fields: [canonicalJobId], references: [id], onDelete: Cascade)

  @@unique([userId, canonicalJobId])
  @@index([userId, status])
}

model UserPreference {
  id           String   @id @default(cuid())
  userId       String
  key          String
  value        String
  isHardFilter Boolean  @default(false)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  user UserProfile @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, key])
}

model UserBehaviorSignal {
  id             String     @id @default(cuid())
  userId         String
  canonicalJobId String
  action         UserAction
  metadata       Json?
  createdAt      DateTime   @default(now())

  user         UserProfile  @relation(fields: [userId], references: [id], onDelete: Cascade)
  canonicalJob JobCanonical @relation(fields: [canonicalJobId], references: [id], onDelete: Cascade)

  // Feed query: exclude passed jobs for a user
  @@index([userId, action])
  @@index([userId, canonicalJobId, action])
}

model IngestionRun {
  id                        String             @id @default(cuid())
  connectorKey              String
  sourceName                String
  sourceTier                SourceTier
  runMode                   IngestionRunMode   @default(MANUAL)
  status                    IngestionRunStatus
  startedAt                 DateTime           @default(now())
  endedAt                   DateTime?
  fetchedCount              Int                @default(0)
  acceptedCount             Int                @default(0)
  rejectedCount             Int                @default(0)
  rawCreatedCount           Int                @default(0)
  rawUpdatedCount           Int                @default(0)
  canonicalCreatedCount     Int                @default(0)
  canonicalUpdatedCount     Int                @default(0)
  dedupedCount              Int                @default(0)
  sourceMappingCreatedCount Int                @default(0)
  sourceMappingUpdatedCount Int                @default(0)
  sourceMappingsRemovedCount Int               @default(0)
  liveCount                 Int                @default(0)
  staleCount                Int                @default(0)
  expiredCount              Int                @default(0)
  removedCount              Int                @default(0)
  skippedReasons            Json?
  runOptions                Json?
  errorSummary              String?
  createdAt                 DateTime           @default(now())
  updatedAt                 DateTime           @updatedAt

  @@index([startedAt(sort: Desc)])
  @@index([sourceName, startedAt(sort: Desc)])
  @@index([status, startedAt(sort: Desc)])
  @@index([runMode, startedAt(sort: Desc)])
}

model TrackedApplication {
  id             String                   @id @default(cuid())
  userId         String
  canonicalJobId String?
  company        String
  roleTitle      String
  roleUrl        String?
  status         TrackedApplicationStatus @default(WISHLIST)
  deadline       DateTime?
  jobDescription String?
  fitAnalysis    String?
  notes          String?
  createdAt      DateTime                 @default(now())
  updatedAt      DateTime                 @updatedAt

  user          User                        @relation(fields: [userId], references: [id], onDelete: Cascade)
  canonicalJob  JobCanonical?               @relation(fields: [canonicalJobId], references: [id], onDelete: SetNull)
  events        TrackedApplicationEvent[]
  tags          TrackedApplicationTag[]
  documentLinks TrackedApplicationDocument[]
  notifications Notification[]
  reminderLogs  ReminderLog[]

  @@unique([userId, canonicalJobId])
  @@index([userId])
  @@index([status])
  @@index([deadline])
  @@index([canonicalJobId])
}

model TrackedApplicationEvent {
  id                 String                       @id @default(cuid())
  trackedApplicationId String
  type               TrackedApplicationEventType
  timestamp          DateTime                     @default(now())
  note               String?
  reminderAt         DateTime?
  reminderNotifiedAt DateTime?

  trackedApplication TrackedApplication @relation(fields: [trackedApplicationId], references: [id], onDelete: Cascade)

  @@index([trackedApplicationId])
  @@index([timestamp])
  @@index([reminderAt])
}

model Tag {
  id           String                 @id @default(cuid())
  userId       String
  name         String

  user         User                   @relation(fields: [userId], references: [id], onDelete: Cascade)
  applications TrackedApplicationTag[]

  @@unique([userId, name])
  @@index([userId])
}

model TrackedApplicationTag {
  trackedApplicationId String
  tagId                String

  trackedApplication TrackedApplication @relation(fields: [trackedApplicationId], references: [id], onDelete: Cascade)
  tag                Tag                @relation(fields: [tagId], references: [id], onDelete: Cascade)

  @@id([trackedApplicationId, tagId])
  @@index([tagId])
}

model TrackedApplicationDocument {
  id                  String                         @id @default(cuid())
  trackedApplicationId String
  documentId          String
  slot                TrackedApplicationDocumentSlot

  trackedApplication TrackedApplication @relation(fields: [trackedApplicationId], references: [id], onDelete: Cascade)
  document           Document           @relation(fields: [documentId], references: [id], onDelete: Cascade)

  @@unique([trackedApplicationId, slot])
  @@index([documentId])
}

model Notification {
  id                  String           @id @default(cuid())
  userId              String
  trackedApplicationId String?
  type                NotificationType
  title               String
  message             String
  readAt              DateTime?
  createdAt           DateTime         @default(now())

  user               User                @relation(fields: [userId], references: [id], onDelete: Cascade)
  trackedApplication TrackedApplication? @relation(fields: [trackedApplicationId], references: [id], onDelete: SetNull)

  @@index([userId, createdAt])
  @@index([trackedApplicationId])
  @@index([readAt])
}

model ReminderLog {
  id                  String               @id @default(cuid())
  userId              String
  trackedApplicationId String
  reminderType        DeadlineReminderType
  deadlineDate        DateTime
  createdAt           DateTime             @default(now())

  user               User               @relation(fields: [userId], references: [id], onDelete: Cascade)
  trackedApplication TrackedApplication @relation(fields: [trackedApplicationId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt])
  @@index([trackedApplicationId])
  @@unique([userId, trackedApplicationId, reminderType, deadlineDate])
}

model Session {
  id        String   @id @default(cuid())
  token     String   @unique
  expiresAt DateTime
  ipAddress String?
  userAgent String?
  userId    String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model Account {
  id                    String    @id @default(cuid())
  accountId             String
  providerId            String
  userId                String
  accessToken           String?
  refreshToken          String?
  idToken               String?
  accessTokenExpiresAt  DateTime?
  refreshTokenExpiresAt DateTime?
  scope                 String?
  password              String?
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([providerId, accountId])
  @@index([userId])
}

model Verification {
  id         String   @id @default(cuid())
  identifier String
  value      String
  expiresAt  DateTime
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
}
